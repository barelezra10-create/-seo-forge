# Postgres — Railway-hosted (used for local dev too)
DATABASE_URL=postgresql://postgres:<password>@switchyard.proxy.rlwy.net:<port>/railway

# Internal Railway URL — used by deployed Railway services
RAILWAY_DATABASE_INTERNAL_URL=postgresql://postgres:<password>@postgres.railway.internal:5432/railway

# Local Postgres.app fallback (offline dev)
LOCAL_DATABASE_URL=postgres://seo_forge:seo_forge@localhost:5432/seo_forge

# API keys
VOYAGE_API_KEY=
AHREFS_API_KEY=
GSC_REFRESH_TOKEN=
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
ANTHROPIC_API_KEY=

# GitHub PATs (one per site, scoped to that single repo)
GH_PAT_MCA_GUIDE=

# Claude Code CLI auth (set if running headless; for 1A we use local user auth)
CLAUDE_HOME=

# Worker config
WORKSPACE_REPOS_DIR=./workspace/repos
